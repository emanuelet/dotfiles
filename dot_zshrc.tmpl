{{- $githubUser := .githubUser | default "emanuelet" -}}
{{- $defaultUser := .chezmoi.username -}}
{{- $isLinux := eq .chezmoi.os "linux" -}}

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load
ZSH_THEME="agnoster"

# Which plugins would you like to load?
plugins=(git zsh-autosuggestions zsh-syntax-highlighting mise)

source $ZSH/oh-my-zsh.sh

# Preferred editor for local and remote sessions
export EDITOR='vim'

prompt_context() {
  if [[ "$USER" != "$DEFAULT_USER" || -n "$SSH_CLIENT" ]]; then
    prompt_segment black default "%(!.%{%F{yellow}%}.)$USER"
  fi
}

alias note='gnome-text-editor'

export GITHUB_USERNAME='{{ $githubUser }}'

{{ if $isLinux -}}
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi
{{- end }}

alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

alias dcd='docker compose down'
alias dcud='docker compose up -d'
alias pn="pnpm"
alias upg='sudo apt update && sudo apt upgrade'

# History
HISTSIZE=2000
SAVEHIST=2000
setopt HIST_IGNORE_ALL_DUPS
setopt SHARE_HISTORY
HISTCONTROL=ignoreboth
DEFAULT_USER="$(whoami)"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac

eval "$(~/.local/bin/mise activate zsh)"

# opencode
export PATH=$HOME/.opencode/bin:$PATH
export PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=ubuntu24.04-x64

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.bifrost/bin:$PATH"
